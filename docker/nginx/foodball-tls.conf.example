# ════════════════════════════════════════════════════════════════════════════
# Production TLS-terminating reverse proxy for FoodBall (example).
# Put in front of the foodball-web container (which serves plain HTTP on :8080).
# Replace DOMAIN_NAME and APP_UPSTREAM, obtain a cert (certbot), then `nginx -t`.
# Derived from the security-hardening nginx template; adds HSTS that is only
# meaningful here (over HTTPS) — the container itself deliberately omits it.
# ════════════════════════════════════════════════════════════════════════════

# Rate-limit zones (place in the http{} block / nginx.conf):
# limit_req_zone $binary_remote_addr zone=app:10m rate=20r/s;

server {
  listen 80;
  listen [::]:80;
  server_name DOMAIN_NAME;
  return 301 https://$host$request_uri;          # force HTTPS
}

server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;
  server_name DOMAIN_NAME;

  ssl_certificate     /etc/letsencrypt/live/DOMAIN_NAME/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/DOMAIN_NAME/privkey.pem;

  # Modern TLS only.
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers off;
  ssl_session_timeout 1d;
  ssl_session_tickets off;
  ssl_stapling on;
  ssl_stapling_verify on;

  # HSTS (preload) — only set over HTTPS.
  add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
  # The app's other security headers come from the container; this proxy only
  # adds HSTS so it isn't sent on plain HTTP.

  client_max_body_size 1m;

  location / {
    limit_req zone=app burst=40 nodelay;
    limit_req_status 429;
    proxy_pass http://APP_UPSTREAM;              # e.g. http://127.0.0.1:8090
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 60s;
  }
}

# After install:
#   certbot certonly --nginx -d DOMAIN_NAME
#   test at https://www.ssllabs.com/ssltest/  (target: A/A+)
